<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Usuário</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; }
        .card { border-radius: 15px; border: none; }
        .card-header { background-color: #0073d1; color: #ffffff; border-radius: 15px 15px 0 0; font-weight: bold; }
    </style>
</head>
<body>

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card shadow">
                    <div class="card-header text-center py-3">
                        Edição de Usuario
                    </div>
                    <div class="card-body p-4">
                        <form>
                            <input value="<%= usuario.id %>" type="hidden" id="usuarioId">

                            <div class="mb-3">
                                <label for="username" class="form-label">Username</label>
                                <input value="<%= usuario.username %>" type="text" id="username" class="form-control">
                            </div>

                            <div class="mb-3">
                                <label for="email" class="form-label">E-mail</label>
                                <input value="<%= usuario.email %>" type="email" id="email" class="form-control">
                            </div>

                            <div class="mb-4">
                                <label for="senha" class="form-label">Nova Senha</label>
                                <input type="password" id="senha" class="form-control" placeholder="••••••••">
                            </div>

                            <div class="d-grid gap-2">
                                <button id="btnSalvarEdicao" class=" btn btn-primary btn-lg" type="submit">
                                    Salvar Alterações
                                </button>
                                <a href="/user/list" class="btn btn-link text-secondary text-decoration-none text-center">
                                    Cancelar e Voltar
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
                <div id="statusMessage" class="mt-3"></div>
            </div>
        </div>
    </div>

</body>
<script>
    const btnSalvarEdicao = document.getElementById("btnSalvarEdicao");
    const statusMessage = document.getElementById("statusMessage");
  
    btnSalvarEdicao.addEventListener("click", salvarUsuario);

    async function salvarUsuario(e) {
        e.preventDefault();

        const id = document.getElementById("usuarioId");
        const username = document.getElementById("username");
        const email = document.getElementById("email");
        const senha = document.getElementById("senha");

        const url = "/user/edit";

        try {
            const response = await fetch(url, { 
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    id: id.value,
                    username: username.value,
                    email: email.value,
                    senha: senha.value
                })
            });

            const data = await response.json();

            if (!response.ok) {
                statusMessage.innerHTML = `<div class="alert alert-danger">Erro ao atualizar dados!</div>`;
            } else {
                statusMessage.innerHTML = `<div class="alert alert-success">Dados atualizados com sucesso!</div>`;
                setTimeout(() => { window.location.href = "/user/list"; }, 1500);
            }
            console.log(data);
        } catch (error) {
            statusMessage.innerHTML = `<div class="alert alert-danger">Erro de conexão com o servidor.</div>`;
        }
    }
</script>
</html>
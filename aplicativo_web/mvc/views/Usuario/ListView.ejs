<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lista de Usuários</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; }
        .container { background-color: white; border-radius: 15px; padding: 30px; }
        .table thead { background-color: #0d6efd; color: white; }
    </style>
</head>
<body>

    <div class="container shadow-sm mt-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3">Gerenciamento de Usuários</h1>
            <a href="/user/create" class="btn btn-primary">
                + Novo Usuário
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Senha</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <% for(usuario of usuarios) { %> 
                        <tr>
                            <td><span class="badge bg-secondary text-white">#<%= usuario.id %></span></td>
                            <td><strong><%= usuario.username %></strong></td> <td><%= usuario.email %></td>
                            <td><code class="text-muted">********</code></td>
                            <td class="text-center">
                                <div class="btn-group" role="group">
                                    <a href="/user/edit/<%= usuario.id %>" class="btn btn-outline-warning btn-sm">
                                        Editar 
                                    </a>
                                    <button onclick="apagarUsuario('<%= usuario.id %>')" class="btn btn-outline-danger btn-sm">
                                        Apagar
                                    </button>
                                </div>
                            </td>
                        </tr>
                    <% } %> 
                </tbody>
            </table>
        </div>
    </div>

</body>

<script>
    async function apagarUsuario(id) {
        if (!confirm("Tem certeza que deseja excluir este usuário?")) return;

        const url = "/user/delete/" + id;

        try {
            const response = await fetch(url, { method: 'DELETE' });
            const data = await response.json();

            if (!response.ok) {
                alert("Ocorreu um erro na requisição");
                console.log("Erro:", data);
            } else {
                console.log("Excluído com sucesso:", data);
                location.reload(); 
            }
        } catch (error) {
            alert("Erro de conexão.");
        }
    }
</script>
</html>